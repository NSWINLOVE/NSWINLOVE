<?php
require __DIR__ . '/session_bootstrap.php';
require __DIR__ . '/csrf.php';
require __DIR__ . '/logger.php';

if (empty($_SESSION['admin_logged_in'])) {
    $configFile = dirname(__DIR__, 2) . '/config/install.php';
    $config = file_exists($configFile) ? require $configFile : [];
    $slug = trim(($config['site']['admin_slug'] ?? 'admin'), '/');
    $slug = $slug !== '' ? $slug : 'admin';
    header('Location: /' . $slug . '/');
    exit;
}

$baseDir = dirname(__DIR__, 2);
$configFile = $baseDir . '/config/install.php';
$config = file_exists($configFile) ? require $configFile : [];
$site = $config['site'] ?? [];
$currentSlug = trim(($site['admin_slug'] ?? 'admin'), '/');
$currentSlug = $currentSlug !== '' ? $currentSlug : 'admin';
$currentPage = 'logs';
$logFile = $baseDir . '/storage/logs/admin-actions.log';
$rows = [];
$message = '';
$error = '';
$q = trim($_GET['q'] ?? '');

function h($value): string { return htmlspecialchars((string)$value, ENT_QUOTES, 'UTF-8'); }

if ($_SERVER['REQUEST_METHOD'] === 'POST' && ($_POST['action'] ?? '') === 'clear_logs') {
    csrf_verify_or_die();
    if (file_exists($logFile)) {
        $backupDir = $baseDir . '/.trash';
        if (!is_dir($backupDir)) {
            mkdir($backupDir, 0777, true);
        }
        $backupFile = $backupDir . '/admin-actions-' . date('Ymd-His') . '.log';
        if (@rename($logFile, $backupFile)) {
            admin_log('clear_logs', ['backup' => basename($backupFile)]);
            $message = '日志已清空，旧日志已移入 .trash。';
        } else {
            $error = '日志清空失败。';
        }
    } else {
        $message = '当前没有可清空的日志。';
    }
}

if (file_exists($logFile)) {
    $lines = @file($logFile, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES) ?: [];
    $lines = array_reverse($lines);
    foreach ($lines as $line) {
        $decoded = json_decode($line, true);
        if (!is_array($decoded)) {
            continue;
        }

        if ($q !== '') {
            $haystack = implode(' ', [
                $decoded['time'] ?? '',
                $decoded['user'] ?? '',
                $decoded['action'] ?? '',
                $decoded['ip'] ?? '',
                json_encode($decoded['data'] ?? [], JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES),
            ]);
            if (mb_stripos($haystack, $q) === false) {
                continue;
            }
        }

        $decoded['_detail'] = json_encode($decoded['data'] ?? [], JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_PRETTY_PRINT);
        $rows[] = $decoded;
        if (count($rows) >= 100) {
            break;
        }
    }
}

require __DIR__ . '/layout-top.php';
?>
